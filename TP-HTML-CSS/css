body {
    font-family: 'Roboto', Arial, sans-serif; /* Define la tipografía base (y alternativas si no carga) */
    background-color: #e9eef3;                /* Pinta el fondo de toda la pantalla de gris azulado claro */
    margin: 0;                                /* Elimina los márgenes externos por defecto del navegador */
    padding: 0;                               /* Elimina el espacio de relleno interno por defecto */
}

.inicio {
    width: 80%;                               /* Ocupa el 80% del ancho de la pantalla */
    max-width: 1200px;                        /* No se estira más allá de 1200px para evitar deformarse */
    margin: 20px auto;                        /* Separa 20px arriba/abajo y centra la caja horizontalmente */
    padding: 10px;                            /* Espacio interno de 10px entre el borde y el contenido */
    background-color: #0c1a30;                /* Fondo de la caja en azul marino muy oscuro */
    border: 1px solid #ccc;                   /* Borde fino de 1 píxel continuo de color gris claro */
    border-radius: 8px;                       /* Redondea las esquinas de la caja con un radio de 8px */
    box-shadow: 0px 4px 10px rgba(0, 0, 0, 0.1); /* Añade una sombra sutil hacia abajo para dar relieve */
}

header {
    background-color: #02162b;                /* Fondo azul oscuro para el encabezado de la web */
    color: white;                             /* Convierte todos los textos de esta sección a blanco */
    padding: 25px;                            /* Espacio de 25px en todos los lados del interior */
    border-radius: 6px;                       /* Esquinas del encabezado levemente redondeadas */
    text-align: center;                       /* Centra todos los elementos y textos de la cabecera */
}

.logo {
    width: 80px;                              /* Fuerza un ancho fijo de 80px para la imagen del logo */
    height: auto;                             /* Escala la altura automáticamente para no distorsionar */
    margin-bottom: 10px;                      /* Deja un espacio de 10px libre debajo de la imagen */
    float: left;                              /* Alinea el logo a la izquierda y permite texto a su lado */
}

nav ul {
    list-style: none;                         /* Quita las viñetas o puntos negros de la lista del menú */
    padding: 0;                               /* Elimina el espacio interno izquierdo de la lista */
    margin: 15px 0 0 0;                       /* Separa el menú 15px únicamente por la parte superior */
}

nav li {
    display: inline;                          /* Pone los elementos de la lista en horizontal (uno al lado de otro) */
    margin: 0 15px;                           /* Separa los enlaces dejando 15px libres a izquierda y derecha */
}

nav a {
    color: white;                             /* Color blanco para los enlaces de navegación */
    text-decoration: none;                    /* Elimina el subrayado clásico de los hipervínculos */
    font-weight: bold;                        /* Aplica un formato de letra en negrita */
}

.contenedor {
    width: 80%;                               /* Ocupa el 80% de ancho de la pantalla */
    max-width: 1200px;                        /* Límite máximo de ancho fijado en 1200px */
    margin: 30px auto;                        /* Separa 30px arriba/abajo y se centra horizontalmente */
    padding: 30px;                            /* Amplio espacio interno de 30px para despejar el contenido */
    background-color: white;                  /* Fondo de este contenedor completamente blanco */
    border: 2px solid #06005c;                /* Borde de 2px de grosor color azul eléctrico